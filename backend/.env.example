DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here
DALAT_AUTO_SYNC_SHEET=true

# Cấu hình Google Sheet (Nếu muốn đổi sang Sheet riêng của bạn)
# DALAT_FNB_SHEET_URL=https://docs.google.com/spreadsheets/d/1-ECVLtuySSlCO5AShcJle1uP9j8XCA4l/edit
# DALAT_FNB_EXPORT_URL=https://docs.google.com/spreadsheets/d/1-ECVLtuySSlCO5AShcJle1uP9j8XCA4l/export?format=xlsx

# Cấu hình đường dẫn ảnh (máy mới chỉ cần set nếu ảnh nằm ngoài thư mục project)
# Nếu không điền, tool tự tìm trong data/images/dalat và data/images/tiktok
# DALAT_IMAGE_DIR=data/images/dalat
# TIKTOK_REFERENCE_DIR=data/images/tiktok

# Thư viện ảnh local (nếu có): copy thư mục ảnh vào data/images/library/
# Tool sẽ tự tìm trong đó khi image-mapping.json trỏ đến path không tồn tại.

# Port (mặc định backend=3000, frontend=3001, tự đổi nếu bận)
# PORT=3000
# FRONTEND_PORT=3001
