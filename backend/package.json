{
  "name": "dalat-tiktok-carousel-tool",
  "version": "0.1.0",
  "private": true,
  "description": "NestJS tool for generating Da Lat TikTok carousel previews from the local workbook and image sets.",
  "scripts": {
    "build": "tsc --noEmit -p tsconfig.json",
    "bundle": "tsc -p tsconfig.build.json && esbuild build/dist/main.js --bundle --platform=node --format=cjs --target=node24 --external:@nestjs/microservices --external:@nestjs/microservices/* --external:@nestjs/websockets --external:@nestjs/websockets/* --external:class-validator --external:class-transformer --outfile=build/dalat_tiktok_carousel_tool_standalone.cjs",
    "sync:sheet": "ts-node src/modules/guide/sync/sync-sheet.ts",
    "start": "node build/dalat_tiktok_carousel_tool_standalone.cjs",
    "start:dev": "ts-node src/main.ts"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.6",
    "@nestjs/core": "^11.1.6",
    "@nestjs/platform-express": "^11.1.6",
    "dotenv": "^17.4.2",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "esbuild": "^0.25.9",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}
